# Claude (same key as Meeting Intelligence)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# Notion (same token and database as Meeting Intelligence)
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=your-database-id-here

# Gmail — use an App Password, NOT your regular Gmail password.
# Setup: Google Account → Security → 2-Step Verification → App passwords
# Generate one for "Mail" and paste it below.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Who receives the digest (defaults to GMAIL_ADDRESS if not set)
DIGEST_RECIPIENT=you@gmail.com

# Blog publishing (safe defaults: local Markdown draft)
BLOG_PUBLISH_ENABLED=true
BLOG_PUBLISH_MODE=local
BLOG_AUTHOR="Gabriel Odeyemi"
BLOG_BASE_URL=https://gabrielodeyemi.com
BLOG_OUTPUT_DIR=./output/blog
BLOG_DEFAULT_STATUS=draft
BLOG_EXISTING_POST_ACTION=skip
BLOG_MIN_WORDS=900
BLOG_MAX_WORDS=1500
BLOG_QUALITY_REVIEW_ENABLED=true
BLOG_MAX_ATTEMPTS=2

# Explicit approval handoff to gabrielodeyemi.com
BLOG_APPROVAL_REQUIRED=true
BLOG_WEBSITE_REPO_PATH=/Users/olugbengaodeyemi/Downloads/personalwebsite
BLOG_WEBSITE_CONTENT_DIR=src/content/blog

# GitHub PR workflow for approved Strategic Digest posts
BLOG_PR_ENABLED=true
BLOG_PR_BASE_BRANCH=main
BLOG_PR_BRANCH_PREFIX=strategic-digest
BLOG_PR_RUN_BUILD=true
